# Cursor API key for the headless `agent` CLI (see README / RUNBOOK).
# Copy this file to `.env` and fill in your keys. Model scripts load `.env` via dotenv.
CURSOR_API_KEY=

# Brin API key — sent as `X-API-Key` on Brin benchmark requests (`scripts/run-brin-benchmark.js` loads `.env`).
BRIN_API_KEY=
